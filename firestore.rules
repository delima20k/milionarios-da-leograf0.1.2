rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Mensagens do grupo ─────────────────────────────────
    // Qualquer usuário autenticado pode ler e criar.
    // Apenas o autor pode apagar.
    match /messages/{msgId} {
      allow read   : if request.auth != null;
      allow create : if request.auth != null
                     && request.resource.data.uid == request.auth.uid;
      allow delete : if request.auth != null
                     && resource.data.uid == request.auth.uid;
    }

    // ── Mensagens privadas ─────────────────────────────────
    // chatId = uid1_uid2 (ordenados). Apenas os dois participantes têm acesso.
    match /privateChats/{chatId}/messages/{msgId} {
      allow read, create : if request.auth != null
                           && (chatId.matches(request.auth.uid + '_.*')
                               || chatId.matches('.*_' + request.auth.uid));
      allow delete       : if request.auth != null
                           && resource.data.uid == request.auth.uid
                           && (chatId.matches(request.auth.uid + '_.*')
                               || chatId.matches('.*_' + request.auth.uid));
    }

    // ── Usuários ───────────────────────────────────────────
    match /users/{userId} {
      allow read  : if request.auth != null;
      allow write : if request.auth != null && request.auth.uid == userId;
    }

    // ── Tokens FCM ─────────────────────────────────────────
    match /fcmTokens/{token} {
      allow read, write : if request.auth != null;
    }

    // ── Chamadas WebRTC ────────────────────────────────────
    match /calls/{callId} {
      allow read, write : if request.auth != null;
    }
    match /calls/{callId}/{sub}/{candId} {
      allow read, write : if request.auth != null;
    }

    // ── Estado da app (Lotofácil) ──────────────────────────
    match /app_state/{docId} {
      allow read : if request.auth != null;
    }
  }
}
