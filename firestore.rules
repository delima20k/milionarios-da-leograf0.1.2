rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Mensagens do grupo ─────────────────────────────────
    // Qualquer usuário autenticado pode ler e criar.
    // O autor ou um administrador (role == 'admin') pode apagar.
    match /messages/{msgId} {
      allow read   : if request.auth != null;
      allow create : if request.auth != null
                     && request.resource.data.uid == request.auth.uid;
      allow delete : if request.auth != null
                     && (resource.data.uid == request.auth.uid
                         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ── Mensagens privadas ─────────────────────────────────
    // chatId = uid1_uid2 (ordenados). Apenas os dois participantes têm acesso.
    // O documento pai (metadado da conversa: unreadFor, lastText, etc.) segue a mesma regra.
    // allow list: necessário para a query where('unreadFor','==',uid) do inbox
    match /privateChats/{chatId} {
      allow get    : if request.auth != null
                     && (chatId.matches(request.auth.uid + '_.*')
                         || chatId.matches('.*_' + request.auth.uid));
      allow list   : if request.auth != null
                     && resource.data.unreadFor == request.auth.uid;
      allow write  : if request.auth != null
                     && (chatId.matches(request.auth.uid + '_.*')
                         || chatId.matches('.*_' + request.auth.uid));
    }
    match /privateChats/{chatId}/messages/{msgId} {
      allow read, create : if request.auth != null
                           && (chatId.matches(request.auth.uid + '_.*')
                               || chatId.matches('.*_' + request.auth.uid));
      allow delete       : if request.auth != null
                           && (chatId.matches(request.auth.uid + '_.*')
                               || chatId.matches('.*_' + request.auth.uid))
                           && (resource.data.uid == request.auth.uid
                               || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ── Chamadas de voz em grupo (WebRTC mesh) ─────────────
    match /groupCalls/{callId} {
      allow read, write : if request.auth != null;
    }
    match /groupCalls/{callId}/{sub}/{docId} {
      allow read, write : if request.auth != null;
    }
    match /groupCalls/{callId}/{sub}/{docId}/{inner}/{innerId} {
      allow read, write : if request.auth != null;
    }

    // ── Usuários ───────────────────────────────────────────
    match /users/{userId} {
      allow read  : if request.auth != null;
      allow write : if request.auth != null && request.auth.uid == userId;
    }

    // ── Tokens FCM ─────────────────────────────────────────
    match /fcmTokens/{token} {
      allow read, write : if request.auth != null;
    }

    // ── Chamadas WebRTC ────────────────────────────────────
    match /calls/{callId} {
      allow read, write : if request.auth != null;
    }
    match /calls/{callId}/{sub}/{candId} {
      allow read, write : if request.auth != null;
    }

    // ── E2E: chave de grupo cifrada por destinatário ───────
    // Cada documento é {uid} do destinatário — só ele pode ler/escrever o seu
    match /groupKeyStore/{uid} {
      allow read, write : if request.auth != null && request.auth.uid == uid;
    }

    // ── E2E P2P: sinalização WebRTC DataChannel ────────────
    // chatId = uid1_uid2 (ordenados) — somente os dois participantes
    match /p2pSignals/{chatId} {
      allow read, write : if request.auth != null
                          && (chatId.matches(request.auth.uid + '_.*')
                              || chatId.matches('.*_' + request.auth.uid));
    }
    match /p2pSignals/{chatId}/ice/{uid}/{candId} {
      allow read, write : if request.auth != null
                          && (chatId.matches(request.auth.uid + '_.*')
                              || chatId.matches('.*_' + request.auth.uid));
    }

    // ── Estado da app (Lotofácil) ──────────────────────────
    match /app_state/{docId} {
      allow read : if request.auth != null;
    }
  }
}
